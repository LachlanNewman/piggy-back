# OIDC provider base URL (e.g. https://accounts.google.com or https://your-tenant.okta.com/oauth2/default)
VITE_OIDC_AUTHORITY=

# Client ID registered with your OIDC provider
VITE_OIDC_CLIENT_ID=

# Redirect URI — must match exactly what is registered with your OIDC provider
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
